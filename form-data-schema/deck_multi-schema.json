                "required": false,
                "embedding": "允许传入"
            },
            {
                "field_name": "filters",
                "description": "维度过滤条件列表（全局生效）",
                "data_type": "array[object]",
                "sample_data": [
                    {
                        "col": "城市",
                        "op": "等于",
                        "val": "北京市"
                    }
                ],
                "required": false,
                "embedding": "允许传入"
            },
            {
                "field_name": "url_params",
                "description": "业务透传参数",
                "data_type": "object",
                "sample_data": {
                    "图层组合": "散点+弧线"
                },
                "required": false,
                "embedding": "允许传入"
            }
