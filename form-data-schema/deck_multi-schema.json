                "data_type": "array[object]",
                "sample_data": null
            },
            {
                "field_name": "deck_slices",
                "description": "deck.gl charts",
                "required": false,
                "embedding": "禁止传入",
                "data_type": "string",
                "sample_data": null
            },
            {
                "field_name": "mapbox_style",
                "description": "Map Style",
                "required": false,
                "embedding": "禁止传入",
                "data_type": "string",
                "sample_data": null
            },
            {
                "field_name": "viewport",
                "description": "地图视角配置（全局生效）",
